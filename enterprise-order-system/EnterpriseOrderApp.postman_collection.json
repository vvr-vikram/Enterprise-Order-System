						"description": "Unique key to ensure idempotency across requests"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"userId\": \"user-123\",\n    \"total\": 150.00,\n    \"productId\": \"prod-101\",\n    \"quantity\": 2\n}"
				},
				"url": {
					"raw": "http://localhost:8080/orders",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"orders"
					]
				},
				"description": "Submits a new order to the system. Succeeds since product prod-101 has 50 units in stock and amount is within payment limits."
			},
			"response": []
		},
		{
			"name": "Create Order (Out of Stock Rollback)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Idempotency-Key",
						"value": "unique-idempotency-key-uuid-102",
						"type": "text",
						"description": "Unique key to ensure idempotency across requests"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"userId\": \"user-123\",\n    \"total\": 150.00,\n    \"productId\": \"prod-101\",\n    \"quantity\": 100\n}"
				},
				"url": {
					"raw": "http://localhost:8080/orders",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"orders"
					]
				},
				"description": "Fails since product prod-101 only has 50 units in stock. The transaction rolls back completely; no order or payment is saved in the database."
			},
			"response": []
		},
